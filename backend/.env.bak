PORT=3000
JWT_SECRET=super-secret-key

# PostgreSQL configuration (Docker service name is 'db')
POSTGRES_DB=multiplayer_games
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Connection URL for backend services
DATABASE_URL=postgresql://postgres:postgres@db:5432/multiplayer_games

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Game service URLs (internal Docker network)
UNO_SERVICE_URL=http://uno-service:3001
CARDS_SERVICE_URL=http://cards-service:3002
CHESS_SERVICE_URL=http://chess-service:3003
SNAKES_SERVICE_URL=http://snakes-service:3004
RUMMY_SERVICE_URL=http://rummy-service:3005
