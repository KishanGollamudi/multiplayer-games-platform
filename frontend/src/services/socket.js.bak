import { io } from 'socket.io-client';

const BASE_URL = 'http://54.87.255.157';

const urls = {
  uno: `${BASE_URL}:3001`,
  cards: `${BASE_URL}:3002`,
  chess: `${BASE_URL}:3003`,
  snakes: `${BASE_URL}:3004`,
  rummy: `${BASE_URL}:3005`
};

const sockets = new Map();

export function getSocket(gameKey, token) {
  if (sockets.has(gameKey)) {
    return sockets.get(gameKey);
  }
  const socket = io(urls[gameKey], {
    autoConnect: false,
    auth: { token }
  });
  sockets.set(gameKey, socket);
  return socket;
}

export function connectSocket(gameKey, token) {
  const socket = getSocket(gameKey, token);
  socket.auth = { token };
  if (!socket.connected) {
    socket.connect();
  }
  return socket;
}
